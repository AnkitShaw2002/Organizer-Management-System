<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('./layout/header.ejs') %>
</head>

<body class="hold-transition sidebar-mini">
<div class="wrapper">

  <!-- ── Navbar ── -->
  <nav class="main-header navbar navbar-expand navbar-white navbar-light">
    <ul class="navbar-nav">
      <li class="nav-item">
        <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
      </li>
      <li class="nav-item d-none d-sm-inline-block">
        <a href="#" class="nav-link">Dashboard</a>
      </li>
    </ul>
    <ul class="navbar-nav ml-auto">
      <li class="nav-item">
        <a class="nav-link text-danger" href="/auth/logout" role="button">
          <i class="fas fa-sign-out-alt"></i> Logout
        </a>
      </li>
    </ul>
  </nav>

  <!-- ── Sidebar ── -->
  <%- include('./layout/sidebar.ejs') %>

  <!-- ── Content Wrapper ── -->
  <div class="content-wrapper">

    
    <!-- ORGANIZER DASHBOARD -->
    <% if (data.role === 'organizer') { %>

      <section class="content-header">
        <div class="container-fluid">
          <div class="row mb-2">
            <div class="col-sm-6">
              <h1><i class="fas fa-calendar-alt mr-2"></i>Organizer Dashboard</h1>
            </div>
            <div class="col-sm-6">
              <p class="text-muted text-right mt-2">Welcome, <strong><%= data.name %></strong></p>
            </div>
          </div>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">

          <!-- Create Event Card -->
          <div class="card card-primary shadow-sm mb-4">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-plus-circle mr-2"></i>Create New Event</h3>
            </div>
            <div class="card-body">
              <div id="createEventAlert"></div>
              <div class="row">
                <div class="col-md-6 form-group">
                  <label>Event Name</label>
                  <input type="text" class="form-control" id="event_name" placeholder="Enter event name">
                </div>
                <div class="col-md-6 form-group">
                  <label>Duration (e.g., 2 hours)</label>
                  
                  <input type="text" class="form-control" id="duration" placeholder="e.g. 1h">
                </div>
              </div>
              <div class="row">
                <div class="col-md-6 form-group">
                  <label>Date and Time</label>
                  <input type="datetime-local" class="form-control" id="eventDateTime">
                </div>
              </div>
              
              <div class="form-group">
                <label>Description</label>
                <textarea class="form-control" id="eventDescription" rows="3" placeholder="Describe the event..."></textarea>
              </div>
            </div>
            <div class="card-footer text-right">
              <button type="button" class="btn btn-primary px-4" id="createEventBtn">
                <i class="fas fa-save mr-1"></i> Create Event
              </button>
            </div>
          </div>

          <!-- All Events Table -->
          <div class="card shadow-sm mb-4">
            <div class="card-header bg-secondary">
              <h3 class="card-title text-white"><i class="fas fa-list mr-2"></i>All Events</h3>
              <div class="card-tools">
                <button class="btn btn-sm btn-light" id="refreshEventsBtn">
                  <i class="fas fa-sync-alt"></i> Refresh
                </button>
              </div>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                  <thead class="thead-dark">
                    <tr>
                      <th>#</th>
                      <th>Event Name</th>
                      <th>Organizer</th>
                      <th>Weekday</th>
                      <th>Time</th>
                      <th>Duration</th>
                      <th>Description</th>
                    </tr>
                  </thead>
                  <tbody id="eventsTableBody">
                    <tr><td colspan="7" class="text-center text-muted py-3">Loading events...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Other Organizers Cards -->
          <hr class="my-4">
          <h4 class="mb-3"><i class="fas fa-users mr-2"></i>All Organizers</h4>
          <div id="organizersListContainer" class="row">
            <div class="col-12 text-center text-muted py-3">Loading organizers...</div>
          </div>

          <!-- Organizer Detail Modal -->
          <div class="modal fade" id="organizerDetailModal" tabindex="-1" role="dialog">
            <div class="modal-dialog modal-lg" role="document">
              <div class="modal-content">
                <div class="modal-header bg-info text-white">
                  <h5 class="modal-title"><i class="fas fa-user-tie mr-2"></i>Organizer Details</h5>
                  <button type="button" class="close text-white" data-dismiss="modal">
                    <span>&times;</span>
                  </button>
                </div>
                <div class="modal-body" id="organizerDetailBody">Loading...</div>
                <div class="modal-footer">
                  <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>

    
    <!-- ATTENDEE DASHBOARD -->
   
    <% } else if (data.role === 'attendee') { %>

      <section class="content-header">
        <div class="container-fluid">
          <div class="row mb-2">
            <div class="col-sm-6">
              <h1><i class="fas fa-ticket-alt mr-2"></i>Attendee Dashboard</h1>
            </div>
            <div class="col-sm-6">
              <p class="text-muted text-right mt-2">Welcome, <strong><%= data.name %></strong></p>
            </div>
          </div>
        </div>
      </section>

      <section class="content">
        <div class="container-fluid">

          <!-- Book Event Card -->
          <div class="card card-success shadow-sm mb-4">
            <div class="card-header">
              <h3 class="card-title"><i class="fas fa-bookmark mr-2"></i>Book an Event</h3>
            </div>
            <div class="card-body">
              <div id="bookingAlert"></div>
              <div class="row">
                <div class="col-md-3 form-group">
                  <label><strong>1. Select Organizer</strong></label>
                  <select class="form-control" id="selectOrganizer">
                    <option value="">-- Choose Organizer --</option>
                  </select>
                </div>
                <div class="col-md-3 form-group">
                  <label><strong>2. Select Event</strong></label>
                  <select class="form-control" id="selectEvent" disabled>
                    <option value="">-- Choose Event --</option>
                  </select>
                </div>
                <div class="col-md-3 form-group">
                  <label><strong>3. Day</strong></label>
                  <select class="form-control" id="selectDay" disabled>
                    <option value="">-- Day --</option>
                  </select>
                </div>
                <div class="col-md-3 form-group">
                  <label><strong>4. Time</strong></label>
                  <select class="form-control" id="selectTime" disabled>
                    <option value="">-- Time --</option>
                  </select>
                </div>
              </div>
            </div>
            <div class="card-footer text-right">
              <button type="button" class="btn btn-success px-4" id="bookEventBtn" disabled>
                <i class="fas fa-check-circle mr-1"></i> Confirm Booking
              </button>
            </div>
          </div>

          <!-- My Bookings Table -->
          <div class="card shadow-sm">
            <div class="card-header bg-dark">
              <h3 class="card-title text-white"><i class="fas fa-clipboard-list mr-2"></i>My Booked Events</h3>
              <div class="card-tools">
                <button class="btn btn-sm btn-light" id="refreshBookingsBtn">
                  <i class="fas fa-sync-alt"></i> Refresh
                </button>
              </div>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                  <thead class="thead-dark">
                    <tr>
                      <th>#</th>
                      <th>Organizer Name</th>
                      <th>Event Name</th>
                      <th>Weekday</th>
                      <th>Time</th>
                      <th>Booked On</th>
                    </tr>
                  </thead>
                  <tbody id="bookingsTableBody">
                    <tr><td colspan="6" class="text-center text-muted py-3">Loading your bookings...</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

        </div>
      </section>

    <% } %>

  </div>
  <!-- /.content-wrapper -->

  <%- include('./layout/footer.ejs') %>

</div>
<!-- /.wrapper -->


<!-- ORGANIZER SCRIPTS — placed after jQuery is loaded -->

<% if (data.role === 'organizer') { %>
<script>

  function loadAllEvents() {
    fetch('/organizer/view/event/list')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var tbody = document.getElementById('eventsTableBody');
        if (!res.status || !res.data || !res.data.length) {
          tbody.innerHTML = '<tr><td colspan="7" class="text-center text-muted py-3">No events found</td></tr>';
          return;
        }
        tbody.innerHTML = res.data.map(function(ev, i) {
          return '<tr>' +
            '<td>' + (i + 1) + '</td>' +
            '<td>' + ev.event_name + '</td>' +
            '<td>' + (ev.organizerName || '-') + '</td>' +
            '<td>' + (ev.weekday || '-') + '</td>' +
            '<td>' + (ev.time || '-') + '</td>' +
            '<td>' + ev.duration + '</td>' +
            '<td>' + ev.eventDescription + '</td>' +
            '</tr>';
        }).join('');
      })
      .catch(function() {
        document.getElementById('eventsTableBody').innerHTML =
          '<tr><td colspan="7" class="text-center text-danger py-3">Failed to load events</td></tr>';
      });
  }

  function loadOrganizers() {
    fetch('/organizer/view/organizer/list')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var container = document.getElementById('organizersListContainer');
        if (!res.status || !res.data || !res.data.length) {
          container.innerHTML = '<div class="col-12 text-center text-muted py-3">No organizers found</div>';
          return;
        }
        container.innerHTML = res.data.map(function(org) {
          var latestEvent = '';
          if (org.events && org.events.length > 0) {
            var ev = org.events[org.events.length - 1];
            latestEvent = '<strong>Latest Event:</strong> ' + ev.event_name + '<br>' +
              '<small class="text-muted">' + (ev.weekday || '') + ' | ' + (ev.time || '') + ' (' + ev.duration + ')</small>';
          } else {
            latestEvent = '<small class="text-muted">No events yet</small>';
          }
          return '<div class="col-md-4 col-sm-6 mb-4">' +
            '<div class="card h-100 shadow-sm">' +
              '<div class="card-body text-center">' +
                '<img src="https://via.placeholder.com/80" class="rounded-circle mb-3" alt="User Image">' +
                '<h5 class="card-title d-block w-100">' + org.name + '</h5>' +
                '<p class="text-muted small">' + org.email + '</p>' +
                '<p class="card-text text-left mt-3">' +
                  '<strong>Total Events:</strong> ' + (org.totalEvents || 0) + '<br>' +
                  latestEvent +
                '</p>' +
              '</div>' +
              '<div class="card-footer bg-white border-top-0">' +
                '<button class="btn btn-outline-info btn-sm btn-block" onclick="viewOrganizerDetails(\'' + org._id + '\')">' +
                  '<i class="fas fa-eye mr-1"></i> View Details' +
                '</button>' +
              '</div>' +
            '</div>' +
          '</div>';
        }).join('');
      })
      .catch(function() {
        document.getElementById('organizersListContainer').innerHTML =
          '<div class="col-12 text-center text-danger py-3">Failed to load organizers</div>';
      });
  }

  function viewOrganizerDetails(id) {
    document.getElementById('organizerDetailBody').innerHTML = '<div class="text-center py-3"><i class="fas fa-spinner fa-spin"></i> Loading...</div>';
    $('#organizerDetailModal').modal('show');

    fetch('/organizer/view/organizer/details/' + id)
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.status) {
          document.getElementById('organizerDetailBody').innerHTML = '<div class="alert alert-danger">Failed to load organizer details</div>';
          return;
        }
        var org = res.data;
        var eventsRows = '';
        if (org.events && org.events.length > 0) {
          eventsRows = org.events.map(function(ev, i) {
            return '<tr>' +
              '<td>' + (i + 1) + '</td>' +
              '<td>' + ev.event_name + '</td>' +
              '<td>' + (ev.weekday || '-') + '</td>' +
              '<td>' + (ev.time || '-') + '</td>' +
              '<td>' + ev.duration + '</td>' +
              '<td>' + ev.eventDescription + '</td>' +
              '</tr>';
          }).join('');
        } else {
          eventsRows = '<tr><td colspan="6" class="text-center text-muted">No events yet</td></tr>';
        }

        document.getElementById('organizerDetailBody').innerHTML =
          '<div class="row mb-3">' +
            '<div class="col-md-6">' +
              '<p><strong><i class="fas fa-user mr-1"></i> Name:</strong> ' + org.name + '</p>' +
              '<p><strong><i class="fas fa-envelope mr-1"></i> Email:</strong> ' + org.email + '</p>' +
            '</div>' +
            '<div class="col-md-6">' +
              '<p><strong><i class="fas fa-calendar mr-1"></i> Total Events:</strong> ' + (org.events ? org.events.length : 0) + '</p>' +
              '<p><strong>Role:</strong> <span class="badge badge-success">' + org.role + '</span></p>' +
            '</div>' +
          '</div>' +
          '<h5 class="mb-3">Events</h5>' +
          '<div class="table-responsive">' +
            '<table class="table table-bordered table-sm">' +
              '<thead class="thead-dark">' +
                '<tr><th>#</th><th>Event Name</th><th>Weekday</th><th>Time</th><th>Duration</th><th>Description</th></tr>' +
              '</thead>' +
              '<tbody>' + eventsRows + '</tbody>' +
            '</table>' +
          '</div>';
      })
      .catch(function() {
        document.getElementById('organizerDetailBody').innerHTML = '<div class="alert alert-danger">Something went wrong</div>';
      });
  }

  document.getElementById('createEventBtn').addEventListener('click', function() {
    var event_name = document.getElementById('event_name').value.trim();
    var eventDescription = document.getElementById('eventDescription').value.trim();
    var duration = document.getElementById('duration').value.trim();
    var eventDateTime = document.getElementById('eventDateTime').value;
    var alertBox = document.getElementById('createEventAlert');
    var btn = this;

    if (!event_name || !eventDescription || !duration || !eventDateTime) {
      alertBox.innerHTML = '<div class="alert alert-warning"><i class="fas fa-exclamation-triangle mr-1"></i> All fields are required</div>';
      return;
    }

    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Creating...';

    fetch('/organizer/create/event/store', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ event_name: event_name, eventDescription: eventDescription, duration: duration, eventDateTime: eventDateTime })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.status) {
        alertBox.innerHTML = '<div class="alert alert-success"><i class="fas fa-check-circle mr-1"></i> ' + res.message + '</div>';
        document.getElementById('event_name').value = '';
        document.getElementById('eventDescription').value = '';
        document.getElementById('duration').value = '';
        document.getElementById('eventDateTime').value = '';
        loadAllEvents();
      } else {
        alertBox.innerHTML = '<div class="alert alert-danger"><i class="fas fa-times-circle mr-1"></i> ' + res.message + '</div>';
      }
    })
    .catch(function() {
      alertBox.innerHTML = '<div class="alert alert-danger">Something went wrong. Try again.</div>';
    })
    .finally(function() {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-save mr-1"></i> Create Event';
      setTimeout(function() { alertBox.innerHTML = ''; }, 5000);
    });
  });

  document.getElementById('refreshEventsBtn').addEventListener('click', loadAllEvents);

  // Init
  loadAllEvents();
  loadOrganizers();

</script>
<% } %>


<!-- ATTENDEE SCRIPTS — placed after jQuery is loaded -->

<% if (data.role === 'attendee') { %>
<script>

  var selectedEventId = null;

  function loadOrganizersDropdown() {
    fetch('/attendee/organizers')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var sel = document.getElementById('selectOrganizer');
        if (!res.status || !res.data || !res.data.length) {
          sel.innerHTML = '<option value="">No organizers found</option>';
          return;
        }
        sel.innerHTML = '<option value="">-- Choose Organizer --</option>' +
          res.data.map(function(o) {
            return '<option value="' + o._id + '">' + o.name + '</option>';
          }).join('');
      })
      .catch(function() {
        document.getElementById('selectOrganizer').innerHTML = '<option value="">Failed to load</option>';
      });
  }

  document.getElementById('selectOrganizer').addEventListener('change', function() {
    var organizerId = this.value;
    var eventSel = document.getElementById('selectEvent');
    var daySel = document.getElementById('selectDay');
    var timeSel = document.getElementById('selectTime');

    eventSel.innerHTML = '<option value="">-- Choose Event --</option>';
    daySel.innerHTML = '<option value="">-- Day --</option>';
    timeSel.innerHTML = '<option value="">-- Time --</option>';
    eventSel.disabled = true;
    daySel.disabled = true;
    timeSel.disabled = true;
    document.getElementById('bookEventBtn').disabled = true;
    selectedEventId = null;

    if (!organizerId) return;

    fetch('/attendee/events/' + organizerId)
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (!res.status || !res.data || !res.data.length) {
          eventSel.innerHTML = '<option value="">No events available</option>';
          return;
        }
        eventSel.innerHTML = '<option value="">-- Choose Event --</option>' +
          res.data.map(function(ev) {
            return '<option value="' + ev._id + '" data-weekday="' + (ev.weekday || '') + '" data-time="' + (ev.time || '') + '">' + ev.event_name + '</option>';
          }).join('');
        eventSel.disabled = false;
      })
      .catch(function() {
        eventSel.innerHTML = '<option value="">Failed to load events</option>';
      });
  });

  document.getElementById('selectEvent').addEventListener('change', function() {
    var daySel = document.getElementById('selectDay');
    var timeSel = document.getElementById('selectTime');
    daySel.innerHTML = '<option value="">-- Day --</option>';
    timeSel.innerHTML = '<option value="">-- Time --</option>';
    daySel.disabled = true;
    timeSel.disabled = true;
    document.getElementById('bookEventBtn').disabled = true;
    selectedEventId = null;

    var opt = this.options[this.selectedIndex];
    if (!opt || !opt.value) return;

    var weekday = opt.getAttribute('data-weekday');
    var time = opt.getAttribute('data-time');
    selectedEventId = opt.value;

    daySel.innerHTML = '<option value="' + weekday + '">' + weekday + '</option>';
    daySel.disabled = false;

    timeSel.innerHTML = '<option value="' + time + '">' + time + '</option>';
    timeSel.disabled = false;

    document.getElementById('bookEventBtn').disabled = false;
  });

  document.getElementById('bookEventBtn').addEventListener('click', function() {
    if (!selectedEventId) return;

    var alertBox = document.getElementById('bookingAlert');
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-1"></i> Booking...';

    fetch('/attendee/book/event', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ eventId: selectedEventId })
    })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.status) {
        alertBox.innerHTML = '<div class="alert alert-success"><i class="fas fa-check-circle mr-1"></i> ' + res.message + '</div>';
        document.getElementById('selectOrganizer').value = '';
        document.getElementById('selectEvent').innerHTML = '<option value="">-- Choose Event --</option>';
        document.getElementById('selectEvent').disabled = true;
        document.getElementById('selectDay').innerHTML = '<option value="">-- Day --</option>';
        document.getElementById('selectDay').disabled = true;
        document.getElementById('selectTime').innerHTML = '<option value="">-- Time --</option>';
        document.getElementById('selectTime').disabled = true;
        selectedEventId = null;
        loadMyBookings();
      } else {
        alertBox.innerHTML = '<div class="alert alert-danger"><i class="fas fa-times-circle mr-1"></i> ' + res.message + '</div>';
      }
    })
    .catch(function() {
      alertBox.innerHTML = '<div class="alert alert-danger">Something went wrong. Try again.</div>';
    })
    .finally(function() {
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-check-circle mr-1"></i> Confirm Booking';
      setTimeout(function() { alertBox.innerHTML = ''; }, 5000);
    });
  });

  function loadMyBookings() {
    fetch('/attendee/my/bookings')
      .then(function(r) { return r.json(); })
      .then(function(res) {
        var tbody = document.getElementById('bookingsTableBody');
        if (!res.status || !res.data || !res.data.length) {
          tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">No bookings yet</td></tr>';
          return;
        }
        tbody.innerHTML = res.data.map(function(b, i) {
          return '<tr>' +
            '<td>' + (i + 1) + '</td>' +
            '<td>' + b.organizerName + '</td>' +
            '<td>' + b.eventName + '</td>' +
            '<td>' + (b.weekday || '-') + '</td>' +
            '<td>' + (b.time || '-') + '</td>' +
            '<td>' + new Date(b.createdAt).toLocaleDateString() + '</td>' +
            '</tr>';
        }).join('');
      })
      .catch(function() {
        document.getElementById('bookingsTableBody').innerHTML =
          '<tr><td colspan="6" class="text-center text-danger py-3">Failed to load bookings</td></tr>';
      });
  }

  document.getElementById('refreshBookingsBtn').addEventListener('click', loadMyBookings);

  // Init
  loadOrganizersDropdown();
  loadMyBookings();

</script>
<% } %>

</body>
</html>
